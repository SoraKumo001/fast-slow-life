[node name="Welcome" type="Label" parent="MainVBox/BodySection/TabContainer/概要/OverviewVBox"]
layout_mode = 2
text = "
【Fast Slow Life】
村人たちに指示を与え、時間（日数）を進めることで自動的に資源を採取し、施設を強化し、
ダンジョンを探索して期限内のボス撃破を目指す街経営RPGシミュレーションです。
"
horizontal_alignment = 1

